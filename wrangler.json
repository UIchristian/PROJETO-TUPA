{
  "name": "projetotupa",
  "compatibility_date": "2026-06-08",
  "main": "tupa-front/dist/server/index.mjs",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "tupa-front/dist/client"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.mjs",
        "**/*.js"
      ]
    }
  ],
  "build": {
    "command": "cd tupa-front && npm install && npm run build"
  }
}
